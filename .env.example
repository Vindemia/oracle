# Database (PostgreSQL)
DB_PASSWORD=changeme_strong_password

# JWT — générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme_random_64_chars_minimum
JWT_REFRESH_SECRET=changeme_different_random_64_chars_minimum

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Client (Vite — préfixe VITE_ obligatoire pour exposition au navigateur)
VITE_API_URL=http://localhost:3001/api

# Docker (production uniquement)
DOCKER_REGISTRY=ghcr.io/your-username
TAG=latest

# Base URL complète PostgreSQL (construite depuis les variables ci-dessus par docker-compose)
# En développement hors Docker, renseigner directement :
DATABASE_URL=postgresql://oracle:changeme_strong_password@localhost:5432/oracle
